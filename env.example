# Copy to .env and fill in (never commit .env).
OPENAI_API_KEY=
PORT=3000

# Firebase web app config — served to the browser via GET /api/firebase-config (not committed in repo).
# Copy values from Firebase Console → Project settings → Your apps → Web app config.
# Set the same variables in Vercel → Environment Variables.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Used by GET /api/lykeion-secrets → merged into window.LYKEION_SECRETS (Helius + Solana Tracker).
# Required for: lykeion-ai wallet tools, demo trading migrated tab / search, demo terminal charts/trades.
# Add the same names in Vercel → Project → Settings → Environment Variables.
HELIUS_API_KEY=
# Also accepted: HELIUS_KEY
SOLANA_TRACKER_API_KEY=
# Also accepted: SOLANA_TRACKER_KEY, SOLANATRACKER_API_KEY

# Browser-only (demo terminal, demo trading, lykeion-ai.js): set window.LYKEION_SECRETS
# before scripts load — e.g. DevTools, or a gitignored scripts/local-secrets.js included
# before ../scripts/bootstrap-secrets.js. Keys: openai, helius, solanaTracker.
#
# Wallet analysis in lykeion-ai.js uses Helius only (no server proxy yet):
#   helius — https://www.helius.dev/ (DAS getAssetsByOwner + enhanced transactions API)
# DexScreener (public) is used for token prices; Solana public RPC for balance fallback.
