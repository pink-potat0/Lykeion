{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "index.js",
          "pages/**",
          "styles/**",
          "scripts/**",
          "assets/**"
        ]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/server.js" }]
}
